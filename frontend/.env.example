# Frontend environment variables (Vite exposes VITE_* via import.meta.env).
# Copy this file to `.env` and adjust as needed.

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000

# API key for protected endpoints. Must match API_KEY on the backend.
# Leave empty if the backend has no API key set.
VITE_API_KEY=

# Set to "true" to use hardcoded mock data from src/api/mock.js
# (no backend required). Set to "false" to call the real API.
VITE_USE_MOCK_API=false
